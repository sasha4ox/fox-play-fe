# State Management with Zustand

## Store Structure

### Basic Store Pattern
```javascript
// store/authStore.js
import { create } from 'zustand';
import { persist } from 'zustand/middleware';

export const useAuthStore = create(
  persist(
    (set, get) => ({
      // State
      user: null,
      token: null,
      isAuthenticated: false,
      isLoading: false,
      
      // Actions
      login: async (credentials) => {
        try {
          set({ isLoading: true });
          
          const response = await api.post('/auth/login', credentials);
          const { user, token } = response;
          
          set({
            user,
            token,
            isAuthenticated: true,
            isLoading: false
          });
          
          return { success: true };
        } catch (error) {
          set({ isLoading: false });
          return { success: false, error: error.message };
        }
      },
      
      logout: () => {
        set({
          user: null,
          token: null,
          isAuthenticated: false
        });
        
        // Clear API token
        api.setAuthToken(null);
      },
      
      updateUser: (userData) => {
        set(state => ({
          user: { ...state.user, ...userData }
        }));
      },
      
      // Selectors (computed values)
      getUser: () => get().user,
      getUserId: () => get().user?.id,
      isAdmin: () => get().user?.role === 'admin'
    }),
    {
      name: 'auth-store', // localStorage key
      partialize: (state) => ({ 
        user: state.user, 
        token: state.token,
        isAuthenticated: state.isAuthenticated 
      })
    }
  )
);
```

### Complex Store with Slices
```javascript
// store/profileStore.js
import { create } from 'zustand';
import { subscribeWithSelector } from 'zustand/middleware';

export const useProfileStore = create(
  subscribeWithSelector((set, get) => ({
    // Profile slice
    profile: null,
    profileLoading: false,
    profileError: null,
    
    // Balance slice
    balance: {},
    balanceLoading: false,
    
    // Orders slice
    orders: [],
    ordersLoading: false,
    
    // Actions
    fetchProfile: async () => {
      try {
        set({ profileLoading: true, profileError: null });
        const profile = await api.get('/me/profile');
        set({ profile, profileLoading: false });
      } catch (error) {
        set({ 
          profileError: error.message, 
          profileLoading: false 
        });
      }
    },
    
    updateProfile: async (updates) => {
      try {
        const updatedProfile = await api.patch('/me/profile', updates);
        set({ profile: updatedProfile });
        return { success: true };
      } catch (error) {
        set({ profileError: error.message });
        return { success: false, error: error.message };
      }
    },
    
    fetchBalance: async () => {
      try {
        set({ balanceLoading: true });
        const balance = await api.get('/me/balance');
        set({ balance, balanceLoading: false });
      } catch (error) {
        set({ balanceLoading: false });
        console.error('Failed to fetch balance:', error);
      }
    },
    
    updateBalance: (currency, amount) => {
      set(state => ({
        balance: {
          ...state.balance,
          [currency]: amount
        }
      }));
    },
    
    // Computed selectors
    getBalanceForCurrency: (currency) => {
      const balance = get().balance;
      return balance[currency] || 0;
    },
    
    getTotalBalanceUSD: () => {
      const balance = get().balance;
      // Calculate total balance in USD
      return Object.entries(balance).reduce((total, [currency, amount]) => {
        // You'd need exchange rates here
        return total + amount;
      }, 0);
    }
  }))
);

// Subscribe to profile changes for side effects
useProfileStore.subscribe(
  (state) => state.profile,
  (profile) => {
    if (profile) {
      // Update page title with user nickname
      document.title = `FoxPlay - ${profile.nickname}`;
    }
  }
);
```

## Store Organization

### Multiple Store Pattern
```javascript
// store/gameStore.js
export const useGameStore = create((set, get) => ({
  games: [],
  selectedGame: null,
  servers: {},
  
  fetchGames: async () => {
    const games = await api.get('/games');
    set({ games });
  },
  
  selectGame: (gameId) => {
    const game = get().games.find(g => g.id === gameId);
    set({ selectedGame: game });
  },
  
  fetchServers: async (gameId) => {
    const servers = await api.get(`/games/${gameId}/servers`);
    set(state => ({
      servers: {
        ...state.servers,
        [gameId]: servers
      }
    }));
  },
  
  getServersForGame: (gameId) => {
    return get().servers[gameId] || [];
  }
}));
```

### Store Composition
```javascript
// store/index.js
export { useAuthStore } from './authStore';
export { useProfileStore } from './profileStore';
export { useGameStore } from './gameStore';
export { useThemeStore } from './themeStore';

// Combined hook for commonly used stores
export function useAppStores() {
  const auth = useAuthStore();
  const profile = useProfileStore();
  const theme = useThemeStore();
  
  return {
    auth,
    profile,
    theme
  };
}
```

## Component Integration

### Using Stores in Components
```javascript
import { useAuthStore } from '@/store/authStore';
import { useProfileStore } from '@/store/profileStore';

// ✅ GOOD - Select only needed state
function UserProfile() {
  const { user, isAuthenticated } = useAuthStore(state => ({
    user: state.user,
    isAuthenticated: state.isAuthenticated
  }));
  
  const { profile, fetchProfile, updateProfile } = useProfileStore(state => ({
    profile: state.profile,
    fetchProfile: state.fetchProfile,
    updateProfile: state.updateProfile
  }));
  
  // Component logic
  return (
    <div>
      {isAuthenticated && <h1>Welcome, {user.nickname}</h1>}
    </div>
  );
}

// ✅ GOOD - Using individual selectors for performance
function UserBalance() {
  const balance = useProfileStore(state => state.balance);
  const getBalanceForCurrency = useProfileStore(state => state.getBalanceForCurrency);
  
  return (
    <div>
      <p>USD: ${getBalanceForCurrency('USD')}</p>
      <p>EUR: €{getBalanceForCurrency('EUR')}</p>
    </div>
  );
}

// ❌ BAD - Selecting entire store causes unnecessary re-renders
function BadExample() {
  const authStore = useAuthStore(); // Re-renders on any auth state change
  
  return <div>{authStore.user?.nickname}</div>;
}
```

### Custom Hooks with Stores
```javascript
// hooks/useAuth.js
import { useAuthStore } from '@/store/authStore';
import { useRouter } from 'next/navigation';

export function useAuth() {
  const router = useRouter();
  const { login, logout, user, isAuthenticated, isLoading } = useAuthStore();
  
  const handleLogin = async (credentials) => {
    const result = await login(credentials);
    if (result.success) {
      router.push('/dashboard');
    }
    return result;
  };
  
  const handleLogout = () => {
    logout();
    router.push('/');
  };
  
  const requireAuth = () => {
    if (!isAuthenticated) {
      router.push('/login');
      return false;
    }
    return true;
  };
  
  return {
    login: handleLogin,
    logout: handleLogout,
    requireAuth,
    user,
    isAuthenticated,
    isLoading
  };
}
```

## Async Actions

### Async State Management
```javascript
export const useOfferStore = create((set, get) => ({
  offers: [],
  loading: {
    fetch: false,
    create: false,
    update: false,
    delete: false
  },
  error: null,
  
  fetchOffers: async (filters = {}) => {
    try {
      set(state => ({
        loading: { ...state.loading, fetch: true },
        error: null
      }));
      
      const offers = await api.get('/offers', { params: filters });
      
      set(state => ({
        offers,
        loading: { ...state.loading, fetch: false }
      }));
      
      return { success: true, data: offers };
    } catch (error) {
      set(state => ({
        loading: { ...state.loading, fetch: false },
        error: error.message
      }));
      
      return { success: false, error: error.message };
    }
  },
  
  createOffer: async (offerData) => {
    try {
      set(state => ({
        loading: { ...state.loading, create: true },
        error: null
      }));
      
      const newOffer = await api.post('/offers', offerData);
      
      set(state => ({
        offers: [newOffer, ...state.offers],
        loading: { ...state.loading, create: false }
      }));
      
      return { success: true, data: newOffer };
    } catch (error) {
      set(state => ({
        loading: { ...state.loading, create: false },
        error: error.message
      }));
      
      return { success: false, error: error.message };
    }
  },
  
  updateOffer: async (offerId, updates) => {
    try {
      set(state => ({
        loading: { ...state.loading, update: true },
        error: null
      }));
      
      const updatedOffer = await api.patch(`/offers/${offerId}`, updates);
      
      set(state => ({
        offers: state.offers.map(offer => 
          offer.id === offerId ? updatedOffer : offer
        ),
        loading: { ...state.loading, update: false }
      }));
      
      return { success: true, data: updatedOffer };
    } catch (error) {
      set(state => ({
        loading: { ...state.loading, update: false },
        error: error.message
      }));
      
      return { success: false, error: error.message };
    }
  }
}));
```

## Real-time Updates

### WebSocket Integration with Store
```javascript
// store/orderStore.js
import { create } from 'zustand';

export const useOrderStore = create((set, get) => ({
  orders: [],
  notifications: [],
  
  addOrder: (order) => {
    set(state => ({
      orders: [order, ...state.orders]
    }));
  },
  
  updateOrder: (orderId, updates) => {
    set(state => ({
      orders: state.orders.map(order =>
        order.id === orderId ? { ...order, ...updates } : order
      )
    }));
  },
  
  addNotification: (notification) => {
    const id = Date.now().toString();
    set(state => ({
      notifications: [
        { ...notification, id, timestamp: new Date() },
        ...state.notifications
      ]
    }));
    
    // Auto-remove notification after 5 seconds
    setTimeout(() => {
      set(state => ({
        notifications: state.notifications.filter(n => n.id !== id)
      }));
    }, 5000);
  },
  
  // WebSocket event handlers
  handleOrderUpdate: (data) => {
    const { updateOrder, addNotification } = get();
    updateOrder(data.orderId, data.updates);
    
    addNotification({
      type: 'info',
      message: `Order ${data.orderId} has been updated`
    });
  },
  
  handleNewMessage: (data) => {
    const { addNotification } = get();
    addNotification({
      type: 'message',
      message: `New message in order ${data.orderId}`,
      orderId: data.orderId
    });
  }
}));

// WebSocket connection hook
export function useOrderSocket() {
  const orderStore = useOrderStore();
  
  useEffect(() => {
    const ws = new WebSocket(process.env.NEXT_PUBLIC_WS_URL);
    
    ws.onmessage = (event) => {
      const data = JSON.parse(event.data);
      
      switch (data.type) {
        case 'ORDER_UPDATE':
          orderStore.handleOrderUpdate(data);
          break;
        case 'NEW_MESSAGE':
          orderStore.handleNewMessage(data);
          break;
      }
    };
    
    return () => ws.close();
  }, []);
}
```

## State Persistence

### Selective Persistence
```javascript
import { create } from 'zustand';
import { persist, createJSONStorage } from 'zustand/middleware';

export const useSettingsStore = create(
  persist(
    (set, get) => ({
      theme: 'system',
      language: 'en',
      notifications: {
        orders: true,
        messages: true,
        payments: false
      },
      
      updateTheme: (theme) => set({ theme }),
      updateLanguage: (language) => set({ language }),
      updateNotificationSettings: (settings) => 
        set(state => ({
          notifications: { ...state.notifications, ...settings }
        }))
    }),
    {
      name: 'user-settings',
      storage: createJSONStorage(() => localStorage),
      // Only persist specific fields
      partialize: (state) => ({
        theme: state.theme,
        language: state.language,
        notifications: state.notifications
      })
    }
  )
);
```

## Testing Store

### Store Testing Pattern
```javascript
// __tests__/authStore.test.js
import { renderHook, act } from '@testing-library/react';
import { useAuthStore } from '@/store/authStore';

// Mock API
jest.mock('@/lib/api', () => ({
  post: jest.fn(),
  setAuthToken: jest.fn()
}));

describe('useAuthStore', () => {
  beforeEach(() => {
    useAuthStore.getState().logout(); // Reset store
  });
  
  it('should login successfully', async () => {
    const mockUser = { id: '1', nickname: 'testuser' };
    const mockToken = 'token123';
    
    require('@/lib/api').post.mockResolvedValue({
      user: mockUser,
      token: mockToken
    });
    
    const { result } = renderHook(() => useAuthStore());
    
    await act(async () => {
      const loginResult = await result.current.login({
        email: 'test@test.com',
        password: 'password'
      });
      expect(loginResult.success).toBe(true);
    });
    
    expect(result.current.user).toEqual(mockUser);
    expect(result.current.token).toBe(mockToken);
    expect(result.current.isAuthenticated).toBe(true);
  });
});
```