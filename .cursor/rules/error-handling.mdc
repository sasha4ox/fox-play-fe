## Error Logging & Monitoring

### Client-Side Error Reporting
```javascript
// lib/errorReporting.js
class ErrorReporter {
  static instance = null;
  
  constructor() {
    if (ErrorReporter.instance) {
      return ErrorReporter.instance;
    }
    
    this.isProduction = process.env.NODE_ENV === 'production';
    this.userId = null;
    
    ErrorReporter.instance = this;
  }
  
  setUser(user) {
    this.userId = user?.id;
  }
  
  reportError(error, context = {}) {
    const errorData = {
      message: error.message,
      stack: error.stack,
      name: error.name,
      timestamp: new Date().toISOString(),
      url: window.location.href,
      userAgent: navigator.userAgent,
      userId: this.userId,
      ...context
    };
    
    // Log to console in development
    if (!this.isProduction) {
      console.error('Error reported:', errorData);
      return;
    }
    
    // Send to monitoring service in production
    this.sendToMonitoringService(errorData);
  }
  
  async sendToMonitoringService(errorData) {
    try {
      await fetch('/api/errors', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(errorData)
      });
    } catch (reportingError) {
      console.error('Failed to report error:', reportingError);
    }
  }
  
  reportApiError(error, requestContext) {
    this.reportError(error, {
      type: 'api_error',
      requestUrl: requestContext.url,
      requestMethod: requestContext.method,
      status: error.status
    });
  }
  
  reportComponentError(error, componentName) {
    this.reportError(error, {
      type: 'component_error',
      componentName
    });
  }
}

export const errorReporter = new ErrorReporter();
```

### Global Error Handlers
```javascript
// lib/globalErrorHandlers.js
import { errorReporter } from './errorReporting';

// Catch unhandled promise rejections
window.addEventListener('unhandledrejection', (event) => {
  console.error('Unhandled promise rejection:', event.reason);
  
  errorReporter.reportError(event.reason, {
    type: 'unhandled_promise_rejection'
  });
});

// Catch uncaught errors
window.addEventListener('error', (event) => {
  console.error('Uncaught error:', event.error);
  
  errorReporter.reportError(event.error, {
    type: 'uncaught_error',
    filename: event.filename,
    lineno: event.lineno,
    colno: event.colno
  });
});

// Catch resource loading errors
window.addEventListener('error', (event) => {
  if (event.target !== window) {
    console.error('Resource loading error:', event.target);
    
    errorReporter.reportError(new Error(`Failed to load resource: ${event.target.src || event.target.href}`), {
      type: 'resource_error',
      element: event.target.tagName,
      src: event.target.src || event.target.href
    });
  }
}, true);
