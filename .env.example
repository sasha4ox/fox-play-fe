# Backend API – required
NEXT_PUBLIC_API_URL=http://localhost:8080

# Google sign-in – optional; if set, "Continue with Google" button appears
# Get from https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
# See foxplay/docs/GOOGLE_OAUTH_SETUP.md for full setup
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Contact form → Telegram (optional; if not set, contact form returns 503 and shows "temporarily unavailable")
# 1. Create bot via @BotFather, get token
# 2. Send a message to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# Deploy / production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# NEXT_PUBLIC_LOCAL_APP_URL=http://localhost:3000
