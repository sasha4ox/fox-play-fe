# Backend API – required
NEXT_PUBLIC_API_URL=http://localhost:8080

# Google sign-in – optional; if set, "Continue with Google" button appears
# Get from https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
# See foxplay/docs/GOOGLE_OAUTH_SETUP.md for full setup
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Deploy / production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# NEXT_PUBLIC_LOCAL_APP_URL=http://localhost:3000
